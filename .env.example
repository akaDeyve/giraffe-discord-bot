# Discord Bot Token (vom Discord Developer Portal)
TOKEN=dein_discord_bot_token_hier

# OpenAI-kompatibler API-Key (z.B. von TensorX AI)
OPENAI_API_KEY=dein_api_key_hier

# Base-URL des AI-Providers
BASE_URL=https://api.openai.com/v1

# AI-Modell (z.B. deepseek/deepseek-v4-flash, gpt-4o, etc.)
AI_MODEL=modell_id

# System-Prompt für den AI-Assistenten
AI_SYSTEM_PROMPT=Du bist ein Discord-Assistent, der kurze und prägnante Antworten gibt.

# Kosten pro Million Input-Tokens (in USD)
PRICE_PER_MIO_INPUT_TOKENS=0.15

# Kosten pro Million Output-Tokens (in USD)
PRICE_PER_MIO_OUTPUT_TOKENS=0.30